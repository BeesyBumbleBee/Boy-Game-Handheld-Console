  64          // --- Function Definitions ---
  65          // Sending control commands to LCD driver (4-bit communication)
  66          void LCD_WriteControl (unsigned char cmd)
  67          {
  68   1              unsigned char LCD_comm = 0;
  69   1              static bit LCD_ready;
  70   1      
  71   1              LCD_RS = False;
  72   1              LCD_RW = False;
  73   1      
  74   1              LCD_comm = cmd >> 4;
  75   1              P2 &= 0xF0;
  76   1              P2 |= LCD_comm;
  77   1      
  78   1              LCD_E = True;
  79   1              LCD_E = False;
  80   1      
  81   1              LCD_comm = cmd & 0x0F;  
  82   1              P2 &=0xF0;      // P2 = P2 & 0xF0
  83   1              P2 |= LCD_comm;
  84   1      
  85   1              LCD_E = True;
  86   1              LCD_E = False;
  87   1      
  88   1              P2 |= 0x0F;     // P2 = P2 | 0x0F
  89   1      
  90   1              LCD_RW = True;
  91   1              LCD_RS = False;
  92   1      
  93   1      
  94   1              LCD_ready = 1;
  95   1              while (LCD_ready == 1)
  96   1              {
  97   2                      LCD_E = True;
  98   2                      LCD_ready = LCD_DB7;
  99   2                      LCD_E = False;
 100   2                      LCD_E = True;
 101   2                      LCD_E = False;
 102   2              }
 103   1      }
 104          
