 118   1              LCD_E = True;
 119   1              LCD_E = False;
 120   1      
 121   1              LCD_data = cmd & 0x0F;  
 122   1              P2 &=0xF0;   
 123   1              P2 |= LCD_data;
 124   1      
 125   1              LCD_E = True;
 126   1              LCD_E = False;
 127   1      
 128   1              P2 |= 0x0F;
 129   1      
 130   1              LCD_RW = True;
 131   1              LCD_RS = False;
 132   1      
 133   1              LCD_ready = 1;
 134   1              while (LCD_ready == 1)
 135   1              {
 136   2                      LCD_E = True;
 137   2                      LCD_ready = LCD_DB7;
 138   2                      LCD_E   = False;
 139   2                      LCD_E   = True;
 140   2                      LCD_E   = False;
 141   2              }
 142   1       }
