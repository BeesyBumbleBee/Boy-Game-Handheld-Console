 106          void LCD_WriteData (unsigned char cmd)
 107          {
 108   1              unsigned char LCD_data = 0;
 109   1              static bit LCD_ready;
 110   1      
 111   1              LCD_RS = True;
 112   1              LCD_RW = False;
 113   1      
 114   1              LCD_data = cmd >> 4;
 115   1              P2 &= 0xF0;
 116   1              P2 |= LCD_data;
 117   1      
