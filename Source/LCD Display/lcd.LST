 187          void LCD_Init(void)
 188           {
 189   1         Sleep(5);
 190   1         P2 = 0x83;
 191   1         LCD_E   = True;
 192   1         Sleep(1);
 193   1         LCD_E   = False;
 194   1         Sleep(2);
 195   1         LCD_E   = True;
 196   1         Sleep(1);
 197   1         LCD_E   = False;
 198   1         Sleep(1);
 199   1         LCD_E   = True;
 200   1         Sleep(1);
 201   1         LCD_E   = False;
 202   1         Sleep(1);
 203   1         LCD_DB4 = False;
 204   1         LCD_E   = True;
 205   1         Sleep(1);
 206   1         LCD_E   = False;
 207   1         Sleep(1);
 208   1         LCD_WriteControl(LCD_CONFIG);     
 209   1         LCD_WriteControl(LCD_CLEAR);      
 210   1         LCD_WriteControl(LCD_DISPLAY_OFF);
 211   1         LCD_WriteControl(LCD_DISPLAY_ON); 
 212   1         LCD_WriteControl(LCD_ENTRY_MODE); 
 213   1         LCD_WriteControl(LCD_CLEAR);      
 214   1       }


