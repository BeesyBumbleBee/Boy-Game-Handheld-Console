 109          void Sleep(unsigned int time) // T0
 110          {       
 111   1              TR0 = 0;
 112   1              if (time < 60) {
 113   2                      TL0 = 0xFF - (time<<2);
 114   2                      TH0 = 0xFF - (time<<2);
 115   2                      TR0 = 1;
 116   2                      while (!TF0) {;}
C51 COMPILER V9.51   LCDDISP_MAIN                                                          02/28/2025 18:58:37 PAGE 3   

 117   2                      TF0 = 0;
 118   2                      TR0 = 0;
 119   2              } else {
 120   2                      time /= 60;
 121   2                      while (time > 0)
 122   2                      {
 123   3                              TL0 &= 0x0;
 124   3                              TH0 &= 0x0;
 125   3                              TR0 = 1;
 126   3                              while (!TF0) {;}
 127   3                              TF0 = 0;
 128   3                              TR0 = 0;
 129   3                              time--;
 130   3                      }
 131   2              }
 132   1      }
