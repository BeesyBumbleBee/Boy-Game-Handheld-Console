 161          void scoreScreen(unsigned char game_id) 
 162          {
 163   1              LoadScreen(MENUS_STORAGE_ADDRESS, 1, 0, 0);
 164   1              LCD_DisplayScreen();
 165   1              SendToSlave(SCORES_ADDRESS, 0x03 | (game_id << 4));
 166   1              WaitForResponse();
 167   1              LCD_DisplayCharacterAt(RECV / 100 + '0', 2, 13);
 168   1              LCD_DisplayCharacterAt(RECV / 10  + '0', 2, 14);
 169   1              LCD_DisplayCharacterAt(RECV % 10  + '0', 2, 15);
 170   1              SendToSlave(SCORES_ADDRESS, 0x04 | (game_id << 4));
 171   1              WaitForResponse();
 172   1              LCD_DisplayCharacterAt(RECV / 100 + '0', 3, 13);
 173   1              LCD_DisplayCharacterAt(RECV / 10  + '0', 3, 14);
 174   1              LCD_DisplayCharacterAt(RECV % 10  + '0', 3, 15);
 175   1              RECV = 0;
 176   1                      
 177   1              while (RECV != '5') 
 178   1              {
