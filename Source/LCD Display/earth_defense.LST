 142          // --- Main Game Loop ---
 143          void StartEarthDefense(void) {
 144   1              unsigned char data pressed_key;
 145   1              unsigned char data tick;
 146   1              unsigned char data game_speed; // the lower the faster
 147   1              ED_difficulty = 8;
 148   1              tick = 0;
 149   1              game_speed = 8;
 150   1              LoadCharacters(ED_STORAGE_ADDRESS, 4);
 151   1              LoadScreen(ED_STORAGE_ADDRESS, 4, 0, 1);
 152   1              
 153   1              LCD_DisplayScreen();
 154   1              ED_GameLoop = 1;
 155   1              while(ED_GameLoop) {
 156   2                      // Each game tick:
 157   2                      // I    - ask keyboard for pressed button
 158   2                      // II   - move player character
 159   2                      // III  - spawn player missile
 160   2                      // IV   - move player missile
 161   2                      // V    - move enemies 
 162   2                      // VI   - spawn enemies
 163   2                      // III - V happends when tick % game_speed == 0
 164   2                      
 165   2                      // I
 166   2                      SendToSlave(KEYPAD_ADDRESS, 0x01);
 167   2                      WaitForResponse();
 168   2                      pressed_key = RECV;
 169   2                      Sleep(10);
 170   2                      
 171   2                      // II
 172   2                      ED_MovePlayer(pressed_key);
 173   2                      
 174   2                      // III
 175   2                      ED_SpawnMissile(pressed_key);
 176   2      
 177   2                      if (tick % game_speed == 0) {
 178   3                              
C51 COMPILER V9.51   EARTH_DEFENSE                                                         02/28/2025 18:45:57 PAGE 4   

 179   3                              // IV
 180   3                              ED_MoveMissile(0);
 181   3                              ED_MoveMissile(1);
 182   3                              
 183   3                              // V
 184   3                              ED_MoveEnemies(0);
 185   3                              ED_MoveEnemies(1);
 186   3                              
 187   3                              // VI
 188   3                              ED_SpawnEnemies();
 189   3                              
 190   3                              tick = 0;
 191   3                      } else {
 192   3                              Sleep(1);
 193   3                      }
 194   2                      
 195   2                      if (!ED_difficulty && game_speed > 3) {
 196   3                              game_speed--;
 197   3                              ED_difficulty = 8;
 198   3                      }                       
 199   2                      tick++;
 200   2                      LCD_DisplayScreen();
 201   2              }
 202   1      }
