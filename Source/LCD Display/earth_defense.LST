 206          void ED_MovePlayer(unsigned char pressed_key) {
 207   1              unsigned char data i;
 208   1              unsigned char data row;
 209   1              unsigned char data col;
 210   1              unsigned char data incr;
 211   1              
 212   1              switch (pressed_key) {
 213   2                      case '1':
 214   2                              row = 0;
 215   2                              incr = 1;
 216   2                              col = 6;
 217   2                      break;
 218   2                      case '3':
 219   2                              row = 0;
 220   2                              incr = 1;
 221   2                              col = 9;
 222   2                      break;
 223   2                      case '7':
 224   2                              row = 3;
 225   2                              incr = -1;
 226   2                              col = 6;
 227   2                      break;
 228   2                      case '9':
 229   2                              row = 3;
 230   2                              incr = -1;
 231   2                              col = 9;
 232   2                      break;
 233   2                      default:
 234   2                              return;
 235   2              }
 236   1              
 237   1              for (i = 0; i < 3; i++) {
 238   2                      if (Screen[( (row + incr) * 16 ) + col] == ED_PLAYER) {
 239   3                              Screen[( (row + incr) * 16 ) + col] = ED_EMPTY;
 240   3                              Screen[( (row + 0) * 16 ) + col] = ED_PLAYER;
C51 COMPILER V9.51   EARTH_DEFENSE                                                         02/28/2025 18:45:57 PAGE 5   

 241   3                      }
 242   2                      row += incr;
 243   2              }
 244   1      }
