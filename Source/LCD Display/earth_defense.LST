 246          void ED_SpawnMissile(unsigned char pressed_key) {
 247   1              unsigned char data col;
 248   1              unsigned char data row;
 249   1              unsigned char data incr;
 250   1              if (pressed_key == '4') {
 251   2                      col = 5;
 252   2                      incr = 1;
 253   2              } else if (pressed_key == '6') {
 254   2                      col = 10;
 255   2                      incr = -1;
 256   2              } else {
 257   2                      return;
 258   2              }
 259   1              
 260   1              for (row = 0; row < 4; row++) {
 261   2                      if (Screen[(row*16) + col + incr] == ED_PLAYER) 
 262   2                              if (Screen[(row*16) + col] == ED_ENEMY_ONE || Screen[(row*16) + col] == ED_ENEMY_TWO) {
 263   3                                      Screen[(row*16) + col] = ED_EXPLOSION;
 264   3      
 265   3                                      SendToSlave(SCORES_ADDRESS, 0x01);
 266   3                                      if (enable_haptics) SendToSlave(MOTORS_ADDRESS, 0x72);
 267   3                                      if (enable_haptics) SendToSlave(MOTORS_ADDRESS, 0x71);
 268   3                                      ED_difficulty--;
 269   3                              } else {
 270   3                                      Screen[(row*16) + col] = ED_MISSILE;
 271   3                              }
 272   2              }
 273   1      }
