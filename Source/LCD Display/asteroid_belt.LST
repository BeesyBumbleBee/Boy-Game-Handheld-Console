 107          // --- Main Game Loop ---
 108          void StartAsteroidBelt(void) {
 109   1              unsigned char data pressed_key;
 110   1              unsigned char data tick;
 111   1              unsigned char data game_speed; // the lower the faster
 112   1              tick = 0;
 113   1              AB_difficulty = 16;
 114   1              game_speed = 6;
 115   1              LoadCharacters(AB_STORAGE_ADDRESS, 2);
 116   1              LoadScreen(AB_STORAGE_ADDRESS, 2, 0, 1);
C51 COMPILER V9.51   ASTEROID_BELT                                                         02/28/2025 18:45:56 PAGE 3   

 117   1              
 118   1              LCD_DisplayScreen();
 119   1              AB_GameLoop = 1;
 120   1              while (AB_GameLoop) {
 121   2                      // Each game tick:
 122   2                      // I - ask keyboard for pressed button
 123   2                      // II - move player character on screen
 124   2                      // III - move asteroids 
 125   2                      // IV - check if scored a point
 126   2                      // V - spawn new asteroids (clear the last column before)
 127   2                      // Then update LCD display
 128   2                      // steps III - V only happen when the move_tick variable reaches certain value -> difficulty
 129   2                      
 130   2                      // I
 131   2                      SendToSlave(KEYPAD_ADDRESS, 0x01);
 132   2                      WaitForResponse();
 133   2                      pressed_key = RECV;
 134   2                      
 135   2                      // II
 136   2                      Sleep(10); // configure for best performance
 137   2                      AB_MovePlayer(pressed_key);
 138   2                      
 139   2                      if (tick == game_speed) {
 140   3                              // III
 141   3                              AB_MoveAsteroids();
 142   3                              
 143   3                              // IV   
 144   3                              AB_CheckScore();
 145   3                              
 146   3                              // V
 147   3                              AB_SpawnAsteroids();
 148   3                              tick = 0;
 149   3                      } else {
 150   3                              // TODO: calculate actual delay
 151   3                              Sleep(4); // counteract the time it would take to do III-V
 152   3                      }
 153   2                      
 154   2                      if (!AB_difficulty && game_speed >= 1) {
 155   3                              game_speed--;
 156   3                              AB_difficulty = 16;
 157   3                      }
 158   2                      
 159   2                      tick++;
 160   2                      LCD_DisplayScreen();
 161   2              }
 162   1      }
